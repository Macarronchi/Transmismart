# TransmiSmart — Variables de entorno
# Copia este archivo como .env y ajusta los valores

# Base de datos PostgreSQL
DATABASE_URL=postgresql://transmismart_user:transmismart_pass_2026@localhost:5432/transmismart

# Puerto del servidor Flask (por defecto: 5000)
PORT=5000

# Modo debug (solo desarrollo)
FLASK_DEBUG=0

# Zona horaria (no cambiar)
TZ=America/Bogota
